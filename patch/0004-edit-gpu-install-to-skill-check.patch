diff --git a/main_installer.sh b/main_installer.sh
index 4f8591e..cbcf533 100755
--- a/main_installer.sh
+++ b/main_installer.sh
@@ -101,6 +101,8 @@ download_scripts() {
     local BASE_URL="https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/refs/heads/${BRANCH}"
     local DOWNLOAD_DIR
     DOWNLOAD_DIR="$(pwd)"
+    local LOCAL_SCRIPT_DIR_OPT="/opt/edge-developer-kit-reference-scripts"
+    local LOCAL_SCRIPT_DIR_ROOT="/root/edge-developer-kit-reference-scripts"
 
     local REQUIRED_SCRIPTS=(
         "gpu_installer.sh"
@@ -109,21 +111,40 @@ download_scripts() {
         "print_summary_table.sh"
     )
 
-    # Download scripts
-    apt update
-    apt install -y curl
-    mkdir -p "$DOWNLOAD_DIR"
-    for script in "${REQUIRED_SCRIPTS[@]}"; do
-        local url="$BASE_URL/$script"
-        local path="$DOWNLOAD_DIR/$script"
-        if curl -fsSL "$url" -o "$path"; then
-            echo "Downloaded: $script"
-        else
+    # Ensure curl is available
+    if ! command -v curl >/dev/null 2>&1; then
+        apt update
         if ! apt-get install -y curl; then
             echo "$S_ERROR Failed to install 'curl' needed to download scripts"
             return 1
         fi
-            return 1
+    fi
+
+    mkdir -p "$DOWNLOAD_DIR"
+
+    # Check for local scripts first (prefer /opt, fallback to /root), otherwise download
+    for script in "${REQUIRED_SCRIPTS[@]}"; do
+        local local_path_opt="$LOCAL_SCRIPT_DIR_OPT/$script"
+        local local_path_root="$LOCAL_SCRIPT_DIR_ROOT/$script"
+        local download_path="$DOWNLOAD_DIR/$script"
+
+        if [ -f "$local_path_opt" ]; then
+            echo "Using local script: $local_path_opt"
+            cp "$local_path_opt" "$download_path"
+            echo "Copied: $script"
+        elif [ -f "$local_path_root" ]; then
+            echo "Using local script: $local_path_root"
+            cp "$local_path_root" "$download_path"
+            echo "Copied: $script"
+        else
+            echo "Local script not found, downloading: $script"
+            local url="$BASE_URL/$script"
+            if curl -fsSL "$url" -o "$download_path"; then
+                echo "Downloaded: $script"
+            else
+                echo "$S_ERROR Failed to download $script from $url"
+                return 1
+            fi
         fi
     done
 
@@ -135,7 +156,7 @@ download_scripts() {
             return 1
         fi
     done
-    echo "All scripts downloaded successfully"
+    echo "All scripts ready"
 
     # Change permissions
     for script in "${REQUIRED_SCRIPTS[@]}"; do
