+// Copyright (C) 2026 Intel Corporation
+// SPDX-License-Identifier: Apache-2.0
+
+import { useMutation, useQuery } from '@tanstack/react-query'
+
+export interface OffsetConfig {
+  offset_x: number
+  offset_y: number
+  offset_z: number
+}
+
+interface SetOffsetConfigResponse {
+  status: boolean
+  offset_x: number
+  offset_y: number
+  offset_z: number
+  message: string
+}
+
+export function useOffsetConfigQuery(workerBaseUrl: string) {
+  return useQuery({
+    queryKey: ['offset-config', workerBaseUrl],
+    queryFn: async (): Promise<OffsetConfig> => {
+      const response = await fetch(`${workerBaseUrl}/robot/offset-config`)
+      if (!response.ok) throw new Error(`Failed with status ${response.status}`)
+      return response.json()
+    },
+    retry: false,
+    staleTime: 0,
+  })
+}
+
+export function useSetOffsetConfigMutation() {
+  return useMutation({
+    mutationFn: async ({
+      workerBaseUrl,
+      offsetX,
+      offsetY,
+      offsetZ,
+    }: {
+      workerBaseUrl: string
+      offsetX: number
+      offsetY: number
+      offsetZ: number
+    }): Promise<SetOffsetConfigResponse> => {
+      const response = await fetch(`${workerBaseUrl}/robot/offset-config`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({
+          offset_x: offsetX,
+          offset_y: offsetY,
+          offset_z: offsetZ,
+        }),
+      })
+      if (!response.ok) {
+        const body = await response.json().catch(() => ({}))
+        throw new Error(
+          (body as { detail?: string }).detail ??
+            `Request failed with status ${response.status}`,
+        )
+      }
+      return response.json()
+    },
+  })
+}
