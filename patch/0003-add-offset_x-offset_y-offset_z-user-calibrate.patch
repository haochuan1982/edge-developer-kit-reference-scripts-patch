+@app.get("/robot/offset-config")
+async def get_offset_config():
+    """Return the current offset_x, offset_y, offset_z from config."""
+    robot_cfg = CONFIG.get("robot", {})
+    return {
+        "offset_x": robot_cfg.get("offset_x", 0),
+        "offset_y": robot_cfg.get("offset_y", 0),
+        "offset_z": robot_cfg.get("offset_z", 0),
+    }
+
+
+@app.post("/robot/offset-config")
+async def set_offset_config(body: dict):
+    """Persist updated offset_x, offset_y, offset_z to config.yaml.
+
+    These offsets are used to align the robot arm coordinate system with the
+    camera coordinate system during object pickup operations.
+    """
+    global CONFIG
+
+    offset_x = body.get("offset_x")
+    offset_y = body.get("offset_y")
+    offset_z = body.get("offset_z")
+
+    if offset_x is None or offset_y is None or offset_z is None:
+        raise HTTPException(
+            status_code=400,
+            detail="All three offset values (offset_x, offset_y, offset_z) are required.",
+        )
+
+    try:
+        offset_x = float(offset_x)
+        offset_y = float(offset_y)
+        offset_z = float(offset_z)
+    except (TypeError, ValueError) as exc:
+        raise HTTPException(
+            status_code=400, detail="Offset values must be numbers."
+        ) from exc
+
+    CONFIG.setdefault("robot", {})["offset_x"] = offset_x
+    CONFIG["robot"]["offset_y"] = offset_y
+    CONFIG["robot"]["offset_z"] = offset_z
+
+    try:
+        await run_blocking(save_config, "config.yaml", CONFIG)
+    except Exception as exc:
+        logger.exception("Failed to save offset config")
+        raise HTTPException(status_code=500, detail=str(exc))
+
+    return {
+        "status": True,
+        "offset_x": offset_x,
+        "offset_y": offset_y,
+        "offset_z": offset_z,
+        "message": "Offset configuration saved successfully.",
+    }
+
+
 # ── ArUco camera calibration ──────────────────────────────────────
 
 ARUCO_ALIGN_TOLERANCE_PX = 15
